		"@types/node": "^26.1.1",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.10",
		"eslint-plugin-storybook": "^10.4.6",
		"globals": "^17.7.0",
		"npm-run-all": "^4.1.5",
		"publint": "^0.3.21",
		"rimraf": "^6.1.3",
		"syncpack": "^15.3.2",
		"tsx": "^4.23.0",
		"turbo": "^2.10.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.63.0"
	}
