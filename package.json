{
	"name": "@paszed/developer-platform",
	"version": "0.1.0",
	"private": true,
	"description": "The internal engineering platform powering Paszed, Verra, and future products.",
	"license": "MIT",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "turbo run build",
		"clean": "turbo run clean && rimraf node_modules",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"verify": "turbo run lint typecheck test",
		"format": "biome format . --write",
		"check": "biome check .",
		"publint": "publint",
		"sync": "syncpack lint"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@changesets/cli": "^2.31.0",
