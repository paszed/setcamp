{
	"compilerOptions": {
		"target": "ES2024",
		"lib": ["DOM", "DOM.Iterable", "ES2024"],

		"module": "ESNext",
		"moduleResolution": "Bundler",

		"jsx": "preserve",
		"strict": true,

		"noEmit": true,
		"incremental": true,

		"esModuleInterop": true,
		"isolatedModules": true,

		"skipLibCheck": true
	},

	"include": ["**/*.ts", "**/*.tsx", "next-env.d.ts"],

	"exclude": ["node_modules"]
}
