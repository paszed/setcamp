{
  "name": "@paszed/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configurations for Paszed projects.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./base": "./dist/base.js",
    "./next": "./dist/next.js",
    "./storybook": "./dist/storybook.js"
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "eslint": "^9"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
