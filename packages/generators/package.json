{
	"name": "@paszed/generators",
	"version": "0.1.0",
	"private": true,
	"description": "Project and package generators for the Paszed Developer Platform.",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"clean": "rimraf dist",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"dependencies": {
		"@paszed/shared": "workspace:*"
	}
}
