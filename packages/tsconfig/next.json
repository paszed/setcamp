{
  "$schema": "https://json.schemastore.org/tsconfig",

  "extends": "./base.json",

  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "target": "ES2024",

    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2024"
    ],

    "jsx": "preserve",

    "allowJs": false,

    "incremental": true,

    "noEmit": true,

    "plugins": [
      {
        "name": "next"
      }
    ]
  }
}
