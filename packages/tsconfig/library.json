{
  "$schema": "https://json.schemastore.org/tsconfig",

  "extends": "./base.json",

  "compilerOptions": {
    "target": "ES2024",

    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2024"
    ],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "jsx": "react-jsx",

    "noEmit": false,

    "exactOptionalPropertyTypes": false,

    "types": [
      "node"
    ]
  }
}
