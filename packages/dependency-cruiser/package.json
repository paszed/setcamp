{
  "name": "@paszed/dependency-cruiser",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Dependency Cruiser configuration for Paszed projects.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
