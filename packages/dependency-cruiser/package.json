  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "dependency-cruiser": "^17"
  },
  "devDependencies": {
    "dependency-cruiser": "^18.0.0"
  }
}
